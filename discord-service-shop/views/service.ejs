<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= service.name %> - <%= shopName %></title>
  <link rel="stylesheet" href="/css/style.css">
  <script src="/js/main.js" defer></script>
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">
      <span class="brand-mark">SO</span>
      <span><%= shopName %></span>
    </a>
    <nav class="nav-links">
      <a href="/">Trang chủ</a>
    </nav>
  </header>

  <main class="page-shell">
    <section class="detail-layout">
      <div class="panel detail-panel">
        <% if (typeof error !== "undefined" && error) { %>
          <div class="alert error"><%= error %></div>
        <% } %>
        <span class="status-badge <%= service.status %>"><%= statusText(service.status) %></span>
        <h1><%= service.name %></h1>
        <div class="price-large"><%= service.price %></div>
        <p><%= service.description %></p>
        <div class="safe-note">
          Website không thu mật khẩu, token, mã 2FA hoặc thông tin đăng nhập nhạy cảm.
        </div>
        <div class="button-row">
          <a class="btn btn-soft" href="/">Quay lại</a>
          <% if (service.status === "in_stock") { %>
            <a class="btn btn-primary" href="/order/<%= service.id %>">Đặt hàng</a>
          <% } else { %>
            <button class="btn btn-disabled" disabled>Hết hàng</button>
          <% } %>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <p><%= shopName %> © <%= currentYear %></p>
  </footer>
</body>
</html>
